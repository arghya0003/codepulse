# ============================================================
# CodePulse — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------- Clerk Auth -------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# Redirect URLs (defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ------------------- App URL ----------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------- Database (Phase 2) -----------
# DATABASE_URL=postgresql://...

# ------------------- Upstash Redis (Phase 3) ------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ------------------- Upstash QStash (Phase 5) -----
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# ------------------- ML Service (Phase 5) ---------
# ML_SERVICE_URL=
# ML_INTERNAL_TOKEN=

# ------------------- Encryption (Phase 2) ---------
# ENCRYPTION_KEY=   # 32-byte hex string for AES-256-GCM

# ------------------- Admin Endpoints ---------------
# Protects /api/setup and /api/migrate — use a strong random secret
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SETUP_SECRET=REPLACE_ME
